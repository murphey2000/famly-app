{
  "expo": {
    "name": "Famly",
    "slug": "famly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-lnl.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon-lnl.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.famly.familymemories",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Famly ben\u00f6tigt Zugriff auf deine Fotos, um Erinnerungen zu teilen.",
        "NSCameraUsageDescription": "Famly ben\u00f6tigt Zugriff auf deine Kamera, um Fotos und QR-Codes aufzunehmen.",
        "NSUserNotificationUsageDescription": "Famly sendet dir Benachrichtigungen \u00fcber neue Erinnerungen und Familienaktivit\u00e4ten."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-lnl.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "io.famlyto.moments",
      "permissions": [
        "READ_MEDIA_IMAGES",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/images/newly.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      "expo-audio",
      [
        "expo-camera",
        {
          "cameraPermission": "Erlaube Famly den Zugriff auf deine Kamera, um QR-Codes zu scannen."
        }
      ]
    ],
    "scheme": "famly",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://7ydcv8e9mjwka8u7gwn76vfwtrtp7ych.app.specular.dev"
    }
  }
}